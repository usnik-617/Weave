WEAVE_ENV=production
WEAVE_REQUIRE_EXTERNAL_SERVICES=1

WEAVE_SECRET_KEY=replace-with-32-plus-random-characters
WEAVE_TRUSTED_HOSTS=weave.example.com,www.weave.example.com
WEAVE_PROXY_HOPS=1
WEAVE_SESSION_SECURE=1
WEAVE_SESSION_SAMESITE=Lax

DATABASE_URL=postgresql://weave:change-me@127.0.0.1:5432/weave

WEAVE_STORAGE_BACKEND=r2
WEAVE_S3_BUCKET=weave-prod
WEAVE_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
WEAVE_S3_REGION=auto
WEAVE_S3_ACCESS_KEY_ID=replace-me
WEAVE_S3_SECRET_ACCESS_KEY=replace-me
WEAVE_S3_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
WEAVE_CDN_BASE_URL=https://cdn.weave.example.com

WEAVE_MEDIA_QUEUE_BACKEND=rq
WEAVE_REDIS_URL=redis://127.0.0.1:6379/0
WEAVE_MEDIA_QUEUE_NAME=weave-media
WEAVE_MEDIA_WORKER_COUNT=2

MAX_UPLOAD_MB=25
POST_TOTAL_UPLOAD_MB=300
UPLOAD_BATCH_MAX_FILES=12
UPLOAD_RATE_LIMIT_COUNT=240
UPLOAD_RATE_LIMIT_WINDOW_SEC=60
UPLOAD_GALLERY_THUMBNAIL_MODE=cover_only
