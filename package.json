{
  "name": "weave-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "sync:static-root": "python scripts/sync_static_root.py",
    "lint:frontend": "python scripts/check_frontend_guardrails.py && python scripts/check_css_duplicates.py",
    "check:sync-static-root": "python scripts/check_static_sync_drift.py",
    "test:quick": "python -m pytest tests/test_spa_static_proxy_contract.py tests/test_post_files_access_contract.py tests/test_admin_routes_contract.py -q",
    "test:full": "python -m pytest -q && npm run check:sync-static-root && npm run test:e2e",
    "test:e2e": "npm run check:sync-static-root && npm run sync:static-root && playwright test",
    "test:e2e:full": "npm run check:sync-static-root && npm run sync:static-root && playwright test --reporter=line",
    "test:load": "powershell -ExecutionPolicy Bypass -File scripts/verify_load.ps1",
    "ops:check": "D:/Blog/Weave/venv/Scripts/python.exe scripts/preflight_ops_check.py --start-local",
    "db:backup": "python scripts/backup_db.py",
    "db:restore": "python scripts/restore_db.py",
    "notify:due": "python scripts/send_due_notifications.py"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  }
}
